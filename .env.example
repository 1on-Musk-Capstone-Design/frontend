VITE_DEV_PROXY_TARGET=http://43.203.229.141:8080

# Optional overrides. In production, keep these unset so the app uses same-origin
# Nginx routes: /api and /api/ws.
# VITE_API_BASE_URL=/api
# VITE_SOCKET_SERVER_URL=/api

# WebRTC TURN relay for cross-network voice calls
# Multiple URLs can be provided as a comma-separated list.
VITE_WEBRTC_TURN_URLS=turn:YOUR_TURN_HOST:3478,turns:YOUR_TURN_HOST:5349
VITE_WEBRTC_TURN_USERNAME=YOUR_TURN_USERNAME
VITE_WEBRTC_TURN_CREDENTIAL=YOUR_TURN_PASSWORD
# relay is recommended when TURN is configured
VITE_WEBRTC_ICE_TRANSPORT_POLICY=relay
